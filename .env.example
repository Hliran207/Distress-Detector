# Backend → MongoDB (use hostname `mongo` when running with Docker Compose)
MONGO_URI=mongodb://mongo:27017/reddit_distress_db

# Optional; must match the database name in your URI path
MONGO_DB_NAME=reddit_distress_db

# Local development without Docker (MongoDB on your machine):
# MONGO_URI=mongodb://127.0.0.1:27017/reddit_distress_db

# Atlas or other remote MongoDB:
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/reddit_distress_db
